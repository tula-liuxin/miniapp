page {
  min-height: 100%;
  background:
    radial-gradient(circle at top right, rgba(242, 185, 138, 0.18) 0, rgba(242, 185, 138, 0) 34%),
    linear-gradient(180deg, #f7efe8 0%, #fbf7f2 40%, #fffdfa 100%);
  color: #2f241c;
  font-size: 28rpx;
  line-height: 1.58;
}

button::after {
  border: none;
}

.page-shell {
  position: relative;
  box-sizing: border-box;
  min-height: 100%;
  padding: 28rpx 24rpx calc(48rpx + env(safe-area-inset-bottom));
}

.page-shell::before {
  content: "";
  position: absolute;
  top: 24rpx;
  right: 8rpx;
  width: 240rpx;
  height: 240rpx;
  background: radial-gradient(circle, rgba(217, 164, 126, 0.18) 0%, rgba(217, 164, 126, 0) 72%);
  pointer-events: none;
}

.hero-card,
.panel,
.list-card,
.stat-card,
.timeline-card {
  position: relative;
  z-index: 1;
  overflow: hidden;
  background: rgba(255, 252, 248, 0.96);
  border: 1rpx solid rgba(188, 144, 108, 0.18);
  border-radius: 32rpx;
  box-shadow: 0 22rpx 48rpx rgba(118, 77, 48, 0.08);
}

.hero-card {
  padding: 32rpx;
  margin-bottom: 22rpx;
  background:
    linear-gradient(145deg, rgba(255, 246, 237, 0.98) 0%, rgba(255, 252, 248, 0.95) 52%, rgba(247, 239, 232, 0.96) 100%);
}

.hero-card::before,
.panel::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 8rpx;
  background: linear-gradient(90deg, rgba(191, 93, 50, 0.9) 0%, rgba(226, 174, 121, 0.72) 60%, rgba(255, 255, 255, 0) 100%);
}

.panel {
  padding: 26rpx;
  margin-bottom: 22rpx;
}

.hero-eyebrow,
.section-kicker {
  font-size: 22rpx;
  letter-spacing: 1.4rpx;
  text-transform: uppercase;
  color: #a16b48;
}

.hero-title-row,
.section-heading {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.hero-title-wrap,
.section-heading-main {
  flex: 1;
  min-width: 0;
}

.panel-title,
.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #3e2f24;
  line-height: 1.34;
  word-break: break-word;
}

.panel-subtitle,
.section-note {
  margin-top: 10rpx;
  color: #7b6557;
  font-size: 24rpx;
  line-height: 1.65;
  word-break: break-word;
}

.muted {
  color: #8a7768;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag,
.status-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1.35;
  color: #8e4d29;
  background: rgba(212, 146, 87, 0.13);
}

.tag-soft,
.status-chip-soft {
  color: #49656c;
  background: rgba(97, 137, 143, 0.13);
}

.tag-danger,
.status-chip-danger {
  color: #8a2c24;
  background: rgba(221, 84, 68, 0.12);
}

.tag-warm {
  color: #8b5a36;
  background: rgba(240, 198, 158, 0.22);
}

.symbol-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 68rpx;
  height: 68rpx;
  border-radius: 22rpx;
  flex: 0 0 68rpx;
  color: #9d4b25;
  font-size: 30rpx;
  font-weight: 700;
  background: linear-gradient(145deg, rgba(255, 232, 214, 0.95) 0%, rgba(255, 248, 241, 0.98) 100%);
  box-shadow: inset 0 0 0 1rpx rgba(191, 93, 50, 0.08);
}

.symbol-badge-soft {
  color: #41666a;
  background: linear-gradient(145deg, rgba(223, 241, 239, 0.94) 0%, rgba(246, 252, 250, 0.98) 100%);
}

.symbol-badge-danger {
  color: #9a3c2f;
  background: linear-gradient(145deg, rgba(252, 226, 222, 0.96) 0%, rgba(255, 246, 245, 0.98) 100%);
}

.grid-two {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.grid-three {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18rpx;
}

.stat-card {
  padding: 22rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #9d4421;
  line-height: 1.2;
}

.stat-label {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #756957;
}

.stat-note {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #947c6a;
}

.action-btn,
.secondary-btn,
.ghost-btn,
.danger-btn {
  width: 100%;
  border-radius: 999rpx;
  font-size: 28rpx;
  min-height: 92rpx;
  line-height: 92rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  white-space: normal;
  font-weight: 600;
}

.action-btn {
  color: #fff8f0;
  background: linear-gradient(135deg, #bf5d32 0%, #dd9863 100%);
  box-shadow: 0 18rpx 28rpx rgba(191, 93, 50, 0.2);
}

.secondary-btn {
  color: #455649;
  background: linear-gradient(135deg, #d6e6df 0%, #f0f4e9 100%);
}

.ghost-btn {
  color: #8e4d29;
  background: rgba(255, 251, 247, 0.92);
  border: 1rpx solid rgba(180, 85, 45, 0.28);
}

.danger-btn {
  color: #fff7f6;
  background: linear-gradient(135deg, #bb4c43 0%, #e27b60 100%);
  box-shadow: 0 18rpx 28rpx rgba(187, 76, 67, 0.16);
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.quick-item {
  padding: 22rpx;
  border-radius: 26rpx;
  background: linear-gradient(150deg, rgba(191, 93, 50, 0.09) 0%, rgba(255, 255, 255, 0.96) 100%);
  border: 1rpx solid rgba(191, 93, 50, 0.12);
}

.quick-head {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.quick-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #4a3a2b;
}

.quick-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #7a6b58;
  line-height: 1.65;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.list-card {
  padding: 24rpx;
}

.list-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #43352a;
  line-height: 1.48;
  word-break: break-word;
}

.list-meta,
.list-body {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #746956;
  line-height: 1.7;
  word-break: break-word;
}

.list-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 20rpx;
}

.list-actions button {
  flex: 1;
  min-width: 0;
}

.empty-hint {
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(245, 236, 227, 0.82);
  border: 1rpx dashed rgba(181, 126, 88, 0.18);
  color: #7b6d5c;
  font-size: 24rpx;
  line-height: 1.68;
  word-break: break-word;
}

.empty-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #655042;
}

.field-group {
  margin-top: 22rpx;
}

.field-label {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #4a3c2d;
  margin-bottom: 12rpx;
  line-height: 1.45;
  word-break: break-word;
}

.field-hint {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #857866;
  line-height: 1.6;
  word-break: break-word;
}

.field-shell {
  border-radius: 24rpx;
  border: 1rpx solid rgba(196, 159, 125, 0.22);
  background: rgba(255, 250, 246, 0.9);
  padding: 20rpx;
}

input,
textarea,
picker-view,
slider {
  width: 100%;
}

.input,
.textarea {
  display: block;
  width: 100%;
  box-sizing: border-box;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #fffdf8;
  border: 1rpx solid rgba(153, 127, 94, 0.24);
  font-size: 28rpx;
  line-height: 88rpx;
  color: #34281f;
  overflow: visible;
}

.textarea {
  min-height: 220rpx;
  padding: 20rpx 24rpx;
  line-height: 1.68;
}

.input {
  height: 88rpx;
}

.choice-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.choice-pill {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(160, 121, 75, 0.1);
  color: #6b5338;
  font-size: 24rpx;
}

.choice-pill.active {
  color: #fff9f2;
  background: linear-gradient(135deg, #b95b30 0%, #d88d58 100%);
}

.divider {
  height: 1rpx;
  margin: 18rpx 0;
  background: rgba(154, 128, 97, 0.14);
}

.chart-row {
  margin-top: 14rpx;
}

.chart-label {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  font-size: 22rpx;
  color: #706655;
  margin-bottom: 8rpx;
}

.chart-track {
  height: 16rpx;
  border-radius: 999rpx;
  background: rgba(210, 192, 168, 0.28);
  overflow: hidden;
}

.chart-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #c65c30 0%, #e3b177 100%);
}

.progress-track {
  height: 14rpx;
  border-radius: 999rpx;
  background: rgba(226, 213, 196, 0.55);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #bf5d32 0%, #e2af79 100%);
}

.timeline-card {
  padding: 24rpx;
  margin-top: 18rpx;
}

.timeline-time {
  font-size: 22rpx;
  color: #866f58;
  line-height: 1.4;
}

.timeline-title {
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #43352a;
  line-height: 1.45;
  word-break: break-word;
}

.timeline-body {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #706655;
  line-height: 1.7;
  word-break: break-word;
}

.hero-metrics {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 22rpx;
}

.hero-metric-card {
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.62);
  border: 1rpx solid rgba(201, 157, 123, 0.18);
}

.hero-metric-label {
  font-size: 22rpx;
  color: #8d735f;
}

.hero-metric-value {
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #8f4422;
}

.inline-note {
  margin-top: 14rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 248, 240, 0.82);
  border: 1rpx solid rgba(194, 150, 110, 0.16);
  color: #6f5949;
  font-size: 23rpx;
  line-height: 1.62;
}

.sticky-submit {
  position: sticky;
  bottom: calc(14rpx + env(safe-area-inset-bottom));
  z-index: 8;
  margin-top: 24rpx;
  padding: 18rpx;
  border-radius: 28rpx;
  background: rgba(255, 251, 248, 0.94);
  box-shadow: 0 18rpx 42rpx rgba(103, 69, 46, 0.14);
  backdrop-filter: blur(10rpx);
}

.sticky-submit .field-hint {
  margin: 0 0 12rpx;
}

.loading-shell {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.loading-card {
  height: 160rpx;
  border-radius: 28rpx;
  background: linear-gradient(90deg, rgba(250, 242, 235, 0.9) 0%, rgba(255, 251, 247, 1) 50%, rgba(250, 242, 235, 0.9) 100%);
}

.hero-title-row,
.section-heading,
.quick-head,
.faq-head,
.preview-top,
.slider-head,
.input-with-value,
.post-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.hero-title-wrap,
.section-heading-main {
  flex: 1;
}

.symbol-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  height: 60rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, rgba(193, 90, 52, 0.14) 0%, rgba(223, 155, 104, 0.2) 100%);
  color: #9f4b28;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.symbol-badge-soft {
  background: rgba(102, 155, 108, 0.14);
  color: #4b7550;
}

.symbol-badge-danger {
  background: rgba(226, 101, 92, 0.14);
  color: #ab423b;
}

.section-note,
.stat-note {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #87715d;
}

.field-shell,
.faq-card,
.preview-card,
.bubble,
.moderation-note,
.plaza-reco-card {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 251, 246, 0.9);
  border: 1rpx solid rgba(191, 93, 50, 0.12);
}

.preview-card.preview-danger {
  background: rgba(255, 244, 241, 0.96);
  border-color: rgba(193, 73, 70, 0.18);
}

.preview-card.preview-warm {
  background: rgba(255, 248, 238, 0.96);
}

.preview-card.preview-soft {
  background: rgba(244, 248, 244, 0.96);
  border-color: rgba(102, 155, 108, 0.18);
}

.preview-score {
  min-width: 128rpx;
  padding: 14rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.72);
  text-align: center;
}

.preview-score-value {
  font-size: 34rpx;
  font-weight: 700;
  color: #a34823;
  line-height: 1.1;
}

.preview-score-label,
.post-meta-stats,
.faq-toggle,
.mini-value {
  font-size: 22rpx;
  color: #85715f;
}

.mini-value {
  min-width: 94rpx;
  margin-left: 18rpx;
  padding-top: 28rpx;
  text-align: right;
  color: #a35c3b;
  font-weight: 700;
}

.tag-warm {
  color: #9e5a1b;
  background: rgba(238, 177, 94, 0.15);
}

.bubble {
  margin-top: 16rpx;
}

.bubble-mine {
  background: rgba(255, 247, 238, 0.92);
}

.bubble-reply {
  background: rgba(240, 247, 240, 0.92);
}

.bubble-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #3d2b1e;
}

.plaza-scroll-row {
  white-space: nowrap;
}

.plaza-scroll-track {
  display: inline-flex;
  gap: 16rpx;
}

.plaza-reco-card {
  display: inline-flex;
  flex-direction: column;
  width: 500rpx;
  box-sizing: border-box;
  vertical-align: top;
}

.post-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.post-actions button {
  flex: 1;
}

.comment-composer {
  margin-top: 18rpx;
}
