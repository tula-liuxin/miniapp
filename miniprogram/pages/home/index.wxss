.home-hero-title {
  position: relative;
  z-index: 1;
  margin-top: 18rpx;
}

.hero-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.progress-card,
.status-card,
.empty-state {
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.62);
  border: 1rpx solid rgba(194, 150, 110, 0.16);
}

.progress-label {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  color: #715d4f;
  font-size: 24rpx;
}

.progress-bar {
  height: 14rpx;
  margin-top: 16rpx;
  border-radius: 999rpx;
  background: rgba(226, 213, 196, 0.55);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #bf5d32 0%, #e2af79 100%);
}

.home-stat-grid {
  margin-bottom: 22rpx;
}

.stat-eyebrow {
  font-size: 22rpx;
  color: #91664a;
  letter-spacing: 1.2rpx;
}

.stat-footnote {
  margin-top: 12rpx;
  color: #8a7667;
  font-size: 22rpx;
  line-height: 1.6;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.section-title-wrap {
  flex: 1;
  min-width: 0;
}

.section-icon,
.quick-icon,
.empty-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 22rpx;
  background: linear-gradient(145deg, rgba(255, 232, 214, 0.95) 0%, rgba(255, 248, 241, 0.98) 100%);
  color: #9d4b25;
  font-size: 30rpx;
  font-weight: 700;
  flex: 0 0 64rpx;
}

.status-card {
  background: linear-gradient(145deg, rgba(255, 247, 241, 0.95) 0%, rgba(255, 252, 248, 0.96) 100%);
}

.status-danger {
  background: linear-gradient(145deg, rgba(255, 239, 236, 0.96) 0%, rgba(255, 248, 246, 0.98) 100%);
}

.task-card {
  padding: 22rpx;
  border-radius: 28rpx;
  background: linear-gradient(160deg, rgba(255, 244, 236, 0.94) 0%, rgba(255, 255, 255, 0.96) 100%);
  border: 1rpx solid rgba(191, 93, 50, 0.12);
}

.task-top,
.quick-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.score-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(240, 198, 158, 0.22);
  color: #8b5a36;
  font-size: 22rpx;
}

.horizontal-scroll {
  white-space: nowrap;
}

.home-scroll-card {
  display: inline-flex;
  flex-direction: column;
  width: 540rpx;
  margin-right: 16rpx;
  padding: 24rpx;
  box-sizing: border-box;
  border-radius: 28rpx;
  background: linear-gradient(160deg, rgba(255, 248, 241, 0.98) 0%, rgba(255, 255, 255, 0.92) 100%);
  border: 1rpx solid rgba(191, 93, 50, 0.12);
  box-shadow: 0 18rpx 40rpx rgba(121, 83, 57, 0.08);
  vertical-align: top;
}

.meta-pair {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 18rpx;
  color: #856f5f;
  font-size: 22rpx;
}

.empty-state {
  text-align: left;
}

.empty-title {
  margin-top: 14rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #665243;
}

.empty-desc {
  margin-top: 10rpx;
  color: #7c6b5d;
  font-size: 24rpx;
  line-height: 1.64;
}

.skeleton-card {
  padding: 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(90deg, rgba(250, 242, 235, 0.9) 0%, rgba(255, 251, 247, 1) 50%, rgba(250, 242, 235, 0.9) 100%);
}

.skeleton-chip,
.skeleton-line {
  border-radius: 999rpx;
  background: rgba(221, 205, 189, 0.62);
}

.skeleton-chip {
  width: 132rpx;
  height: 32rpx;
}

.skeleton-line {
  height: 24rpx;
  margin-top: 16rpx;
}

.skeleton-line.medium {
  width: 72%;
}

.skeleton-line.short {
  width: 40%;
}

.tag-success {
  color: #447265;
  background: rgba(102, 168, 142, 0.14);
}
