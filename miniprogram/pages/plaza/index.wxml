<view class="page-shell" id="page-plaza">
  <view class="hero-card">
    <view class="section-kicker">健康广场</view>
    <view class="hero-title-row" style="margin-top: 14rpx;">
      <view class="hero-title-wrap">
        <view class="panel-title">把真实经验分享给需要的人</view>
        <view class="panel-subtitle">这里更像互助社区，而不是数据列表。你可以发布、互动，也可以回看审核状态。</view>
      </view>
      <view class="symbol-badge">广</view>
    </view>
    <button id="button-open-post-editor" class="action-btn" bindtap="openComposer" style="margin-top: 22rpx;">发布经验分享</button>
  </view>

  <view class="panel">
    <view class="section-heading">
      <view class="section-heading-main">
        <view class="section-kicker">首页推荐</view>
        <view class="section-title">先看看大家收藏和互动最多的内容</view>
      </view>
      <view class="symbol-badge symbol-badge-soft">荐</view>
    </view>

    <scroll-view scroll-x class="plaza-scroll-row" show-scrollbar="false" style="margin-top: 18rpx;">
      <view class="plaza-scroll-track">
        <view wx:for="{{recommendedPosts}}" wx:key="id" class="plaza-reco-card">
          <view class="tag tag-soft">推荐内容</view>
          <view class="list-title">{{item.title}}</view>
          <view class="list-body">{{item.excerpt}}</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="panel">
    <view class="section-heading">
      <view class="section-heading-main">
        <view class="section-kicker">最新分享</view>
        <view class="section-title">每条内容都带着真实的恢复过程</view>
      </view>
      <view class="symbol-badge">帖</view>
    </view>

    <view class="card-list" style="margin-top: 18rpx;">
      <view wx:for="{{posts}}" wx:key="id" class="list-card plaza-post-card">
        <view class="post-head">
          <view class="tag-row">
            <view class="tag">{{item.authorName}}</view>
            <view class="tag {{item.statusToneClass}}">{{item.statusLabel}}</view>
            <view class="tag tag-soft">{{item.createdAtLabel}}</view>
          </view>
          <view class="post-meta-stats">{{item.commentCount}} 条评论</view>
        </view>

        <view wx:if="{{item.status !== 'approved'}}" class="moderation-note">
          内容已进入审核流程，审核通过后会对更多患者可见。
        </view>

        <view class="list-title">{{item.title}}</view>
        <view class="list-body">{{item.content}}</view>

        <view class="tag-row" style="margin-top: 18rpx;">
          <view wx:for="{{item.tags}}" wx:key="index" class="tag tag-warm">{{item}}</view>
        </view>

        <view class="post-actions">
          <button
            class="ghost-btn {{item.likedByMe ? 'ghost-btn-active' : ''}}"
            bindtap="likePost"
            data-id="{{item.id}}"
            disabled="{{busyActions['like-' + item.id]}}"
          >
            {{item.likedByMe ? '已点赞' : '点赞'}} {{item.likes}}
          </button>
          <button
            class="ghost-btn {{item.favoritedByMe ? 'ghost-btn-active' : ''}}"
            bindtap="favoritePost"
            data-id="{{item.id}}"
            disabled="{{busyActions['favorite-' + item.id]}}"
          >
            {{item.favoritedByMe ? '已收藏' : '收藏'}} {{item.favorites}}
          </button>
        </view>

        <view class="post-actions" wx:if="{{item.isOwner}}">
          <button class="secondary-btn" bindtap="editPost" data-id="{{item.id}}">编辑内容</button>
          <button class="danger-btn" bindtap="deletePost" data-id="{{item.id}}" disabled="{{busyActions['delete-' + item.id]}}">删除</button>
        </view>

        <view class="comment-composer">
          <text class="field-label">评论交流</text>
          <input
            class="input"
            placeholder="写下你的鼓励、追问或补充"
            value="{{commentDrafts[item.id]}}"
            data-id="{{item.id}}"
            bindinput="onCommentInput"
          />
          <button
            class="secondary-btn"
            bindtap="submitComment"
            data-id="{{item.id}}"
            style="margin-top: 14rpx;"
            disabled="{{busyActions['comment-' + item.id]}}"
          >
            发表评论
          </button>
        </view>

        <view class="card-list" style="margin-top: 18rpx;" wx:if="{{item.comments.length}}">
          <view wx:for="{{item.comments}}" wx:key="id" class="timeline-card">
            <view class="timeline-time">{{item.createdAtLabel}}</view>
            <view class="timeline-title">{{item.authorName}}</view>
            <view class="timeline-body">{{item.content}}</view>
          </view>
        </view>

        <view wx:if="{{!item.comments.length}}" class="empty-inline">还没有评论，欢迎留下第一条鼓励或提问。</view>
      </view>
    </view>

    <view wx:if="{{!posts.length}}" class="empty-hint">
      <view class="empty-title">还没有分享内容</view>
      <view style="margin-top: 12rpx;">欢迎发布第一条康复经验，让后来的人少一点慌张。</view>
    </view>
  </view>
</view>
