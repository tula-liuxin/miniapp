.preview-card {
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.68);
  border: 1rpx solid rgba(194, 150, 110, 0.16);
}

.preview-soft {
  background: linear-gradient(145deg, rgba(241, 248, 244, 0.95) 0%, rgba(255, 252, 248, 0.98) 100%);
}

.preview-warm {
  background: linear-gradient(145deg, rgba(255, 246, 236, 0.96) 0%, rgba(255, 251, 246, 0.98) 100%);
}

.preview-danger {
  background: linear-gradient(145deg, rgba(255, 238, 235, 0.96) 0%, rgba(255, 248, 246, 0.98) 100%);
}

.preview-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.preview-score {
  min-width: 132rpx;
  padding: 16rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.7);
  text-align: center;
}

.preview-score-value {
  font-size: 38rpx;
  font-weight: 700;
  color: #9d4421;
}

.preview-score-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #85715f;
}

.input-with-value {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.input-with-value .input {
  flex: 1;
}

.slider-head {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: center;
}

.mini-value {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 108rpx;
  padding: 0 18rpx;
  height: 72rpx;
  border-radius: 20rpx;
  background: rgba(255, 245, 236, 0.92);
  color: #8f4a26;
  font-size: 24rpx;
  font-weight: 700;
}
